# Copy to `.env.local` for local development (never commit real secrets).

# Node API base URL (no trailing slash). Vite exposes only vars prefixed with VITE_.
# If omitted while running `npm run dev`, the app defaults to http://127.0.0.1:3001.
# Set explicitly when your backend runs elsewhere (e.g. staging or another port).
VITE_API_BASE_URL=http://127.0.0.1:3001
