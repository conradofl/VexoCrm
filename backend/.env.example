# VexoCrm/backend/.env.example
# Copy to .env and fill with real values.
# For EasyPanel: add these vars in the app's Environment section.
#
# Docker: `backend/.env` is NOT copied into the image (.dockerignore). Production only sees variables
# you define in EasyPanel (or docker run -e / compose env). Duplicate CORS_ORIGINS there or CORS will fail in the browser.
#
# Production on VPS (recommended):
# 1) Set DATABASE_URL to your VPS Postgres connection string.
# 2) Set DB_DRIVER=postgres (explicit; avoids accidental Supabase-only mode).
# 3) Remove or leave unset DATA_SOURCE (never use DATA_SOURCE=supabase if you want VPS Postgres).
# 4) Redeploy / restart the container after changing env.
# 5) Verify logs show: [database] Using direct PostgreSQL (pg)
# 6) Verify GET /health includes services.postgresPing: true

# Server
NODE_ENV=production
PORT=3001
# Local `npm run dev` / `npm start`: runs `scripts/conditional-migrate.mjs` once before the API (needs DATABASE_URL or SUPABASE_DB_URL).
# Skip that step: SKIP_DB_MIGRATE=1
# CORS_ORIGINS = browser origins allowed to call this API (exact string match). List every URL where users open the CRM
# (scheme + host, no path). Example: https://your-app.vercel.app — NOT the API host (e.g. NOT easypanel backend URL).
# Vercel Preview: each *.vercel.app preview needs its full origin here, or use a stable production domain only.
# Optional: FRONTEND_ORIGIN=https://your-app.vercel.app — single SPA URL merged into the allow list (easier on EasyPanel).
# In production, '*' in CORS_ORIGINS is ignored — list real origins and/or FRONTEND_ORIGIN. If none parse, the API temporarily allows any browser Origin (insecure; fix env).
# Frontend Vite default port is 8080 (frontend/vite.config.ts). Include it when NODE_ENV=production locally.
CORS_ORIGINS=https://crm.vexoia.com,https://vexo-crm-front.vercel.app,https://vexocrm.vercel.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
# Temporary debugging: when true in production, 500 INTERNAL_ERROR responses include error.details (cause, pg code). Turn off after fixing.
# EXPOSE_INTERNAL_ERROR_DETAILS=true

# Direct PostgreSQL (VPS) — set in production EasyPanel
# DB_DRIVER=postgres forces the pg pool + SQL compat client (requires DATABASE_URL).
# DB_DRIVER=supabase forces @supabase/supabase-js even if DATABASE_URL is set (for comparisons).
# Legacy: if DATABASE_URL is set and DATA_SOURCE is not "supabase", Postgres is used automatically.
# Example (uncomment in .env or set in EasyPanel — replace host, user, password, db name):
# DATABASE_URL=postgresql://user:password@your-vps-host:5432/your_database?sslmode=require
# DB_DRIVER=postgres
# Do not set DATA_SOURCE=supabase when targeting VPS Postgres.
# From Docker/EasyPanel: DATABASE_URL host must be reachable from inside the container (public VPS IP, internal service name, or host gateway — not 127.0.0.1 for Postgres on the Docker host unless you use host networking).
# Optional pool tuning when using DATABASE_URL:
# PG_POOL_MAX=20
# PG_CONNECTION_TIMEOUT_MS=20000
# HEALTH_PG_PING_TIMEOUT_MS=4000

# Supabase (used when DB_DRIVER=supabase, or when DATABASE_URL is unset, or DATA_SOURCE=supabase)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_DB_PASSWORD=your-db-password
# Optional alternative to SUPABASE_ACCESS_TOKEN + SUPABASE_DB_PASSWORD
# SUPABASE_DB_URL=postgresql://postgres.project-ref:password@db.project-ref.supabase.co:5432/postgres
# Docker/EasyPanel (start.sh): 0 = skip migrate on boot. Local npm uses conditional-migrate.mjs instead (see NODE_ENV note above).
RUN_SUPABASE_MIGRATIONS_ON_START=0

# Webhooks (Bearer token for Authorization header)
# POST /api/lead-webhook — same secret as Supabase Edge lead-webhook when migrating n8n (default @Vexo2026 if unset).
# LEAD_WEBHOOK_BEARER_TOKEN=@Vexo2026
# POST /api/conversation-memory, GET /api/conversation-memory/latest, POST /api/n8n-error-webhook — default Bearer @Vexo2026 if unset.
# N8N_WEBHOOK_SECRET=@Vexo2026
N8N_DISPATCH_WEBHOOK_URL=https://your-n8n-host/webhook/dispatch-leads
N8N_DISPATCH_WEBHOOK_TOKEN=optional-shared-secret
# Optional tenant-scoped dispatch fallback. Prefer saving this in lead_client_n8n_settings.
# Keys can be the clientId/tenantId (for example "infinie") or the uppercase suffix.
# EVOLUTION_DISPATCH_WEBHOOKS_JSON={"infinie":{"url":"https://evolution.example/message/sendText/instance","token":"optional"}}
# EVOLUTION_DISPATCH_WEBHOOK_URL_INFINIE=https://evolution.example/message/sendText/instance
# EVOLUTION_DISPATCH_WEBHOOK_TOKEN_INFINIE=optional

# Campaign scheduler
# Keep enabled on a single backend replica to avoid parallel schedulers.
CAMPAIGN_SCHEDULER_ENABLED=true
CAMPAIGN_RUNNER_INTERVAL_MS=60000
# Bearer token required by POST /api/campaigns/run-due.
CAMPAIGN_SCHEDULER_TOKEN=change-this-scheduler-token

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Groq assistivo para campanhas (opcional)
GROQ_API_KEY=your-groq-api-key
GROQ_CAMPAIGN_AI_MODEL=openai/gpt-oss-20b
